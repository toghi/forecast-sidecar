infra/**/.terraform/
infra/**/.terraform.tfstate.lock.info
*.tfstate
*.tfstate.*
*.tfplan
*.tfplan.json
# infra/**/.terraform.lock.hcl IS committed (locks provider versions)

# IDEs / editor
.idea/
.vscode/
*.swp
*.swo

