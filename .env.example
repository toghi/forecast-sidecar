# Forecast Sidecar — example environment file
# Copy to .env (gitignored) for local dev; cloud envs source these from
# Cloud Run env bindings + Google Secret Manager (FR-036).

# --- HTTP server ---
PORT=8080

# --- Storage ---
# Bucket holding model artifacts. Local: served by fake-gcs-server.
FORECAST_BUCKET=local-dev-bucket

# Local dev: point the GCS client at the in-cluster fake (set by compose.yaml).
# Cloud envs: leave unset.
GCS_FAKE_HOST=

# --- Auth (FR-018, FR-019, FR-020, FR-041) ---
# OIDC audience this service expects. Cloud Run URL in deployed envs.
EXPECTED_AUDIENCE=http://localhost:8080

# Comma-separated allowed caller SA emails. MUST be non-empty in cloud envs
# (FR-041); empty allowed locally only.
ALLOWED_CALLERS=

# Local-only OIDC bypass. Honored ONLY when EXPECTED_AUDIENCE is localhost
# AND LOG_LEVEL=debug (FR-018 / R6 startup gate).
AUTH_BYPASS=1

# --- Cache (FR-022) ---
MODEL_CACHE_SIZE=100
MODEL_CACHE_TTL_SECONDS=3600
LATEST_POINTER_TTL_SECONDS=60

# --- Observability ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
LOG_LEVEL=debug

# --- Build provenance (Constitution I) ---
# Injected at container build time via --build-arg GIT_SHA=$(git rev-parse HEAD).
GIT_SHA=local

# --- Trainer ---
# When set to 1, trainer accepts file:// URLs for history/feature_config.
# Production deploys MUST leave unset.
FORECAST_ALLOW_FILE_URLS=1
